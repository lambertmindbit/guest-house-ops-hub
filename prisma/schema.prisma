// Prisma schema for the Guest House Ops Hub (Phase 1).
//
// IMPORTANT — the correctness core lives partly in raw SQL (see the init
// migration), because Prisma cannot express it:
//   * `stay` / `period` are real Postgres DATERANGE columns, GENERATED from
//     check_in/check_out (resp. start/end) as half-open `[)` ranges. They are
//     declared here as `Unsupported("daterange")?` so Prisma tracks the column
//     but never tries to write it — Postgres always derives it.
//   * The no-double-booking guarantee is a GiST EXCLUDE constraint on
//     reservations.stay, added by hand in the init migration.
// Do not try to "fix" these into normal Prisma fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through the Supabase pooler (port 6543, pgbouncer=true) so
  // serverless functions reuse warm connections instead of doing a TLS handshake
  // per request. Migrations need a DIRECT connection (port 5432) — pgbouncer's
  // transaction pooling can't run them. DIRECT_URL falls back to DATABASE_URL
  // locally if you keep using the direct connection in dev.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReservationStatus {
  confirmed
  cancelled
  no_show
}

// Access roles. owner sees everything; reception is blocked from money
// (finance/analytics/pricing) and setup; housekeeping is limited to today +
// cleaning. Extensible later (e.g. manager).
enum UserRole {
  owner
  reception
  housekeeping
}

// A login account. NOT tenant-scoped (login looks up by email before a tenant is
// known); each user belongs to one property via propertyId. Owner is seeded from
// OWNER_EMAIL/OWNER_PASSWORD on first login.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(reception)
  active       Boolean  @default(true)
  propertyId   String?  @map("property_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

// How a block came to exist: created by the owner, or imported from an OTA's
// iCal feed. Imported blocks are owned by the sync and replaced on each run.
enum BlockSource {
  manual
  ical
}

enum AttendanceStatus {
  present
  absent
  leave
}

// Operational staff — distinct from User (a login). A staff member may or may
// not have an account. Tenant-scoped.
model Staff {
  id         String       @id @default(cuid())
  name       String
  role       String? // free-text: housekeeping, cook, reception, delivery, …
  phone      String?
  active     Boolean      @default(true)
  propertyId String?      @map("property_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  shifts     Shift[]
  attendance Attendance[]

  @@map("staff")
}

model Shift {
  id         String   @id @default(cuid())
  staffId    String   @map("staff_id")
  date       DateTime @db.Date
  start      String // "09:00"
  end        String // "17:00"
  note       String?
  propertyId String?  @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@map("shifts")
}

model Attendance {
  id         String           @id @default(cuid())
  staffId    String           @map("staff_id")
  date       DateTime         @db.Date
  status     AttendanceStatus @default(present)
  note       String?
  propertyId String?          @map("property_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  staff      Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([date])
  @@map("attendance")
}

enum HkTaskStatus {
  pending
  in_progress
  done
}

// A cleaning task for a room on a date — the assignment + checklist + completion
// accountability layered over the derived "needs cleaning" signal. assignee/
// completedBy are plain staff ids (nullable). One task per room per day.
model HousekeepingTask {
  id                 String       @id @default(cuid())
  roomId             String       @map("room_id")
  date               DateTime     @db.Date
  assigneeStaffId    String?      @map("assignee_staff_id")
  status             HkTaskStatus @default(pending)
  checklist          Json         @default("[]")
  completedByStaffId String?      @map("completed_by_staff_id")
  completedAt        DateTime?    @map("completed_at")
  note               String?
  propertyId         String?      @map("property_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  room               Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([date])
  @@map("housekeeping_tasks")
}

enum MaintenanceStatus {
  open
  in_progress
  done
}

enum MaintenancePriority {
  low
  medium
  high
}

// A tracked asset/equipment (geyser, generator, vehicle…). preventiveEveryDays +
// lastServicedAt drive the "service due" list.
model Asset {
  id                  String    @id @default(cuid())
  name                String
  category            String?
  roomId              String?   @map("room_id")
  preventiveEveryDays Int?      @map("preventive_every_days")
  lastServicedAt      DateTime? @map("last_serviced_at") @db.Date
  propertyId          String?   @map("property_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("assets")
}

// A repair/maintenance request. assignee/vendor/asset/room are plain nullable ids
// (vendor is linked in slice g). Photos reuse the existing Supabase Storage seam.
model MaintenanceRequest {
  id              String              @id @default(cuid())
  title           String
  description     String?
  assetId         String?             @map("asset_id")
  roomId          String?             @map("room_id")
  status          MaintenanceStatus   @default(open)
  priority        MaintenancePriority @default(medium)
  assigneeStaffId String?             @map("assignee_staff_id")
  vendorId        String?             @map("vendor_id")
  cost            Decimal?            @db.Decimal(10, 2)
  photoPaths      String[]            @default([]) @map("photo_paths")
  note            String?
  propertyId      String?             @map("property_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  resolvedAt      DateTime?           @map("resolved_at")

  @@index([status, priority, createdAt])
  @@map("maintenance_requests")
}

// A supply/stock item. quantity is derived by applying StockMovements; low when
// quantity <= minThreshold.
model InventoryItem {
  id           String          @id @default(cuid())
  name         String
  unit         String? // pcs, kg, bottles…
  quantity     Int             @default(0)
  minThreshold Int             @default(0) @map("min_threshold")
  propertyId   String?         @map("property_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  movements    StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id         String        @id @default(cuid())
  itemId     String        @map("item_id")
  delta      Int // +in / -out
  reason     String?
  byStaffId  String?       @map("by_staff_id")
  propertyId String?       @map("property_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("stock_movements")
}

enum PoStatus {
  draft
  ordered
  received
}

enum TripStatus {
  planned
  done
  cancelled
}

enum ReviewStatus {
  pending
  sent
  received
  responded
}

// A review request/tracker. ROOT sends the actual request (messaging seam); the
// OTA tracks status + drafts a response. guest/reservation are plain nullable ids.
model ReviewRequest {
  id            String       @id @default(cuid())
  guestId       String?      @map("guest_id")
  reservationId String?      @map("reservation_id")
  channel       String       @default("Google")
  status        ReviewStatus @default(pending)
  rating        Int? // 1–5, once received
  link          String?
  responseDraft String?      @map("response_draft")
  propertyId    String?      @map("property_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("review_requests")
}

// Property amenity catalog (Wi-Fi, parking, meals, pets, wheelchair, pickup…).
// Existence = the property offers it. Room-type coverage is the join below. Seeds
// the Phase-3 searchable directory (not built here).
model Amenity {
  id         String            @id @default(cuid())
  name       String
  propertyId String?           @map("property_id")
  createdAt  DateTime          @default(now()) @map("created_at")
  roomTypes  RoomTypeAmenity[]

  @@map("amenities")
}

model RoomTypeAmenity {
  id         String   @id @default(cuid())
  roomTypeId String   @map("room_type_id")
  amenityId  String   @map("amenity_id")
  propertyId String?  @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, amenityId])
  @@index([amenityId])
  @@map("room_type_amenities")
}

// A cab/transport record for history + finance. LIVE dispatch stays in the ROOT
// CabAgent — this repo only records trips. driver/guest/reservation are plain
// nullable ids.
model Driver {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  vehicleNumber String?  @map("vehicle_number")
  active        Boolean  @default(true)
  propertyId    String?  @map("property_id")
  createdAt     DateTime @default(now()) @map("created_at")
  trips         Trip[]

  @@map("drivers")
}

model Trip {
  id            String     @id @default(cuid())
  driverId      String?    @map("driver_id")
  guestId       String?    @map("guest_id")
  reservationId String?    @map("reservation_id")
  pickup        String
  dropoff       String
  scheduledAt   DateTime?  @map("scheduled_at")
  status        TripStatus @default(planned)
  fare          Decimal?   @db.Decimal(10, 2)
  note          String?
  propertyId    String?    @map("property_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  driver        Driver?    @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@map("trips")
}

model Vendor {
  id         String          @id @default(cuid())
  name       String
  category   String?
  contact    String?
  rating     Int? // 1–5
  notes      String?
  propertyId String?         @map("property_id")
  createdAt  DateTime        @default(now()) @map("created_at")
  pos        PurchaseOrder[]
  payments   VendorPayment[]

  @@map("vendors")
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  vendorId    String    @map("vendor_id")
  description String
  amount      Decimal   @db.Decimal(10, 2)
  status      PoStatus  @default(draft)
  note        String?
  propertyId  String?   @map("property_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  receivedAt  DateTime? @map("received_at")
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("purchase_orders")
}

model VendorPayment {
  id         String       @id @default(cuid())
  vendorId   String       @map("vendor_id")
  amount     Decimal      @db.Decimal(10, 2)
  mode       PaymentMode?
  note       String?
  paidAt     DateTime     @default(now()) @map("paid_at")
  propertyId String?      @map("property_id")
  vendor     Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_payments")
}

// Audit trail for sensitive reads/writes (cancel, refund, blacklist, user &
// consent changes). actorUserId is the acting login (nullable for system/env).
model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  action      String // e.g. "reservation.cancel", "user.create"
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  summary     String?
  propertyId  String?  @map("property_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_events")
}

enum PaymentMode {
  cash
  upi
  card
  bank
  ota_collect
}

// Lifecycle of a parsed inbound (OTA email) booking awaiting the owner's review.
enum InboundStatus {
  pending
  imported
  dismissed
}

model RoomType {
  id           String            @id @default(cuid())
  name         String
  baseRate     Decimal           @map("base_rate") @db.Decimal(10, 2)
  maxOccupancy Int               @map("max_occupancy")
  rateFloor    Decimal           @map("rate_floor") @db.Decimal(10, 2)
  rateCeiling  Decimal           @map("rate_ceiling") @db.Decimal(10, 2)
  rooms        Room[]
  amenities    RoomTypeAmenity[]

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("room_types")
}

model Room {
  id                String             @id @default(cuid())
  roomTypeId        String             @map("room_type_id")
  label             String
  // Housekeeping: a room "needs cleaning" when a guest has checked out since
  // this timestamp. Marking a room clean sets it to now.
  lastCleanedAt     DateTime?          @map("last_cleaned_at")
  // Manual override: lets the owner flag a room dirty when there's no checkout
  // to derive from (dust, maintenance, own use). Cleared on "mark clean".
  needsCleaningFlag Boolean            @default(false) @map("needs_cleaning_flag")
  // Retiring a room: archived rooms drop off the calendar, availability,
  // housekeeping, and the new-booking picker, but their history is preserved
  // (FKs are RESTRICT — a used room can never be hard-deleted, only archived).
  archivedAt        DateTime?          @map("archived_at")
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations      Reservation[]
  blocks            Block[]
  icalFeeds         IcalFeed[]
  housekeepingTasks HousekeepingTask[]

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("rooms")
}

model Channel {
  id              String        @id @default(cuid())
  name            String
  commissionPct   Decimal       @map("commission_pct") @db.Decimal(5, 2)
  collectsPayment Boolean       @map("collects_payment")
  reservations    Reservation[]

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("channels")
}

model Guest {
  id                      String            @id @default(cuid())
  name                    String
  phone                   String            @unique
  email                   String?
  notes                   String?
  // Government ID reference (text only — no document/photo upload, which would
  // need object storage). Blacklist flag warns the owner at booking time.
  idNumber                String?           @map("id_number")
  // Path to a scanned ID document in object storage (Supabase Storage). Null
  // until uploaded; storage is optional and configured via env (see docs).
  idDocumentPath          String?           @map("id_document_path")
  // Compliance trail for guest ID capture (police/registration expectations).
  // idUploaded is set by the ID-document upload route; the rest are owner-ticked.
  idChecked               Boolean           @default(false) @map("id_checked")
  idPhotocopied           Boolean           @default(false) @map("id_photocopied")
  idUploaded              Boolean           @default(false) @map("id_uploaded")
  idVerificationCompleted Boolean           @default(false) @map("id_verification_completed")
  // Fields recorded on paper today but never in the DB.
  address                 String?           @map("address")
  vehicleNumber           String?           @map("vehicle_number")
  emergencyContactName    String?           @map("emergency_contact_name")
  emergencyContactPhone   String?           @map("emergency_contact_phone")
  // Free-form preference tags (room/food/allergy/pet, etc.).
  preferences             String[]          @default([]) @map("preferences")
  blocked                 Boolean           @default(false)
  blockReason             String?           @map("block_reason")
  // Guest consent to store their details (privacy). Set when captured.
  consentGivenAt          DateTime?         @map("consent_given_at")
  consentChannel          String?           @map("consent_channel")
  // C-Form (Form C under Registration of Foreigners Rules, 1992).
  // All nullable — only populated for foreign national guests.
  nationality             String?           @map("nationality")
  passportNumber          String?           @map("passport_number")
  passportIssueDate       DateTime?         @map("passport_issue_date") @db.Date
  passportIssuePlace      String?           @map("passport_issue_place")
  passportExpiry          DateTime?         @map("passport_expiry") @db.Date
  visaNumber              String?           @map("visa_number")
  visaType                String?           @map("visa_type")
  visaIssueDate           DateTime?         @map("visa_issue_date") @db.Date
  visaIssuePlace          String?           @map("visa_issue_place")
  visaExpiry              DateTime?         @map("visa_expiry") @db.Date
  portOfEntry             String?           @map("port_of_entry")
  arrivalInIndia          DateTime?         @map("arrival_in_india") @db.Date
  purposeOfVisit          String?           @map("purpose_of_visit")
  reservations            Reservation[]
  outboundMessages        OutboundMessage[]
  complaints              Complaint[]

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("guests")
}

model Reservation {
  id              String                    @id @default(cuid())
  roomId          String                    @map("room_id")
  guestId         String                    @map("guest_id")
  channelId       String                    @map("channel_id")
  otaRef          String?                   @map("ota_ref")
  checkIn         DateTime                  @map("check_in") @db.Date
  checkOut        DateTime                  @map("check_out") @db.Date
  // Generated in the DB from check_in/check_out as a half-open [) daterange.
  stay            Unsupported("daterange")? @map("stay")
  status          ReservationStatus         @default(confirmed)
  // Live arrival/departure stamps. Orthogonal to `status` (a confirmed booking
  // may or may not be in-house yet) and to `stay`, so the exclusion constraint
  // is untouched. Drive the Today board's in-house view + housekeeping handoff.
  checkedInAt     DateTime?                 @map("checked_in_at")
  checkedOutAt    DateTime?                 @map("checked_out_at")
  arrivalTime     String?                   @map("arrival_time")
  specialRequests String?                   @map("special_requests")
  grossAmount     Decimal?                  @map("gross_amount") @db.Decimal(10, 2)
  // Amount expected upfront to hold the room. Separate from grossAmount so the
  // owner can track whether the deposit has arrived before check-in.
  advanceRequired Decimal?                  @map("advance_required") @db.Decimal(10, 2)
  createdAt       DateTime                  @default(now()) @map("created_at")

  // Optional link into a booking group (whole-property / long-stay folio). Each
  // grouped reservation is still a normal single-room booking created through the
  // guarded path, so the no-double-booking guarantee is untouched.
  groupId String? @map("group_id")

  room             Room              @relation(fields: [roomId], references: [id])
  guest            Guest             @relation(fields: [guestId], references: [id])
  channel          Channel           @relation(fields: [channelId], references: [id])
  payments         Payment[]
  outboundMessages OutboundMessage[]
  refunds          Refund[]
  complaints       Complaint[]
  group            BookingGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId       String?           @map("property_id")

  @@index([roomId])
  @@index([guestId])
  @@index([groupId])
  @@map("reservations")
}

// A wrapper linking several single-room reservations into one folio (whole
// property, group, or long stay). Does NOT create bookings — children are made
// the normal way and attached here — so the GiST 409 guarantee is preserved.
model BookingGroup {
  id           String        @id @default(cuid())
  name         String
  guestId      String?       @map("guest_id") // lead guest (optional)
  notes        String?
  propertyId   String?       @map("property_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  reservations Reservation[]

  @@map("booking_groups")
}

// Money received against a reservation. A booking can have several (e.g. a
// deposit then the balance). Sum of payments vs gross_amount gives the balance.
model Payment {
  id            String      @id @default(cuid())
  reservationId String      @map("reservation_id")
  amount        Decimal     @db.Decimal(10, 2)
  mode          PaymentMode
  // True when this payment is the advance/deposit (not the final balance).
  isAdvance     Boolean     @default(false) @map("is_advance")
  paidAt        DateTime    @default(now()) @map("paid_at")
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId    String?     @map("property_id")

  @@index([reservationId])
  @@map("payments")
}

model Block {
  id          String                    @id @default(cuid())
  roomId      String                    @map("room_id")
  startDate   DateTime                  @map("start_date") @db.Date
  endDate     DateTime                  @map("end_date") @db.Date
  // Generated in the DB from start_date/end_date as a half-open [) daterange.
  period      Unsupported("daterange")? @map("period")
  reason      String?
  source      BlockSource               @default(manual)
  // Set for imported blocks: which feed they came from and the source event UID.
  feedId      String?                   @map("feed_id")
  externalUid String?                   @map("external_uid")
  room        Room                      @relation(fields: [roomId], references: [id])
  feed        IcalFeed?                 @relation(fields: [feedId], references: [id], onDelete: Cascade)
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId  String?                   @map("property_id")

  @@index([roomId])
  @@index([feedId])
  @@map("blocks")
}

// A booking parsed out of an OTA confirmation email, staged for the owner to
// review and confirm before it becomes a real Reservation. Decouples "how the
// email arrives" (paste now; inbox webhook later) from "what we do with it".
// Parsed fields are best-effort and nullable — the owner corrects on review.
model InboundBooking {
  id            String        @id @default(cuid())
  source        String // detected channel, e.g. "Booking.com" / "Agoda" / "Unknown"
  otaRef        String?       @map("ota_ref") // used to dedupe re-sent emails
  rawText       String        @map("raw_text")
  guestName     String?       @map("guest_name")
  guestPhone    String?       @map("guest_phone")
  checkIn       DateTime?     @map("check_in") @db.Date
  checkOut      DateTime?     @map("check_out") @db.Date
  roomTypeHint  String?       @map("room_type_hint")
  amount        Decimal?      @db.Decimal(10, 2)
  status        InboundStatus @default(pending)
  reservationId String?       @map("reservation_id") // set once imported
  createdAt     DateTime      @default(now()) @map("created_at")
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId    String?       @map("property_id")

  @@index([status])
  @@map("inbound_bookings")
}

// A cost the property incurred. Attributed to Finance by `date`. Turns the
// revenue-only view into true net profit (revenue − commission − expenses).
model Expense {
  id          String       @id @default(cuid())
  date        DateTime     @db.Date
  category    String
  amount      Decimal      @db.Decimal(10, 2)
  note        String?
  paymentMode PaymentMode? @map("payment_mode")
  createdAt   DateTime     @default(now()) @map("created_at")
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId  String?      @map("property_id")

  @@index([date])
  @@map("expenses")
}

// Single configurable pricing policy (one row). The pricing engine starts from a
// room type's base_rate and compounds the applicable adjustments below, then
// clamps to [rate_floor, rate_ceiling]. All adjustments are advisory — they only
// suggest a nightly rate and pre-fill the booking amount; nothing is pushed to OTAs.
// Percentages may be negative (a discount). Zero / null = that rule is off.
model PricingPolicy {
  id                    String   @id @default(cuid())
  enabled               Boolean  @default(true)
  // Weekday numbers (0=Sun … 6=Sat) that count as "weekend", + their uplift.
  weekendDays           Int[]    @default([5, 6]) @map("weekend_days")
  weekendAdjustPct      Decimal  @default(0) @map("weekend_adjust_pct") @db.Decimal(6, 2)
  // Early-bird discount when the booking is at least N days out.
  leadEarlyDays         Int?     @map("lead_early_days")
  leadEarlyAdjustPct    Decimal? @map("lead_early_adjust_pct") @db.Decimal(6, 2)
  // Last-minute uplift when the booking is within M days of check-in.
  leadLateDays          Int?     @map("lead_late_days")
  leadLateAdjustPct     Decimal? @map("lead_late_adjust_pct") @db.Decimal(6, 2)
  // Occupancy uplift when that night's derived occupancy ≥ threshold %.
  occupancyThresholdPct Int?     @map("occupancy_threshold_pct")
  occupancyAdjustPct    Decimal? @map("occupancy_adjust_pct") @db.Decimal(6, 2)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("pricing_policy")
}

// A named date range (festival / peak season) with a rate adjustment. Inclusive
// of both endpoints. Owner-managed in Settings.
model Season {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  adjustPct Decimal  @map("adjust_pct") @db.Decimal(6, 2)

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("seasons")
}

// An explicit nightly rate the owner pins for a room type on a specific date.
// Overrides win over every rule (and over the floor/ceiling clamp).
model RateOverride {
  id         String   @id @default(cuid())
  roomTypeId String   @map("room_type_id")
  date       DateTime @db.Date
  rate       Decimal  @db.Decimal(10, 2)
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String?  @map("property_id")

  @@unique([roomTypeId, date])
  @@map("rate_overrides")
}

// Single-row table holding the owner's property profile. Read with findFirst;
// the first save creates the row. Used by invoices/receipts and as defaults
// (check-in/out times) elsewhere.
model PropertySettings {
  id           String   @id @default(cuid())
  name         String   @default("My Guest House")
  checkInTime  String   @default("14:00") @map("check_in_time")
  checkOutTime String   @default("11:00") @map("check_out_time")
  currency     String   @default("INR")
  timezone     String   @default("Asia/Kolkata")
  address      String?
  gstNumber    String?  @map("gst_number")
  // UPI VPA (e.g. name@bank) used to build a pay-to-me UPI link/QR for guests.
  upiVpa       String?  @map("upi_vpa")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // Community directory profile (Phase 3). Opt-in; blank/false until the owner
  // fills them in. `isDiscoverable` is the master switch to appear in the peer
  // directory at all (used by slice b). PropertySettings is the tenant ROOT, so
  // these live here rather than on a scoped table.
  publicName     String?  @map("public_name")
  bio            String?
  locality       String?
  contactPhone   String?  @map("contact_phone")
  photoPaths     String[] @map("photo_paths")
  priceBand      String?  @map("price_band")
  lat            Float?
  lng            Float?
  isDiscoverable Boolean  @default(false) @map("is_discoverable")

  @@map("property_settings")
}

// ───────────────────────────────────────────────────────────────────────────
// COMMUNITY NETWORK (Phase 3) — "Rapido for homestays"
// Cross-tenant tables: each references TWO properties, so they are deliberately
// NOT in TENANT_MODELS (src/lib/prisma.ts) — the tenant extension would inject a
// single propertyId and break them. ALL access goes through src/lib/community/*,
// which requires an accepted NetworkConnection AND an enabled SharingGrant before
// reading any peer data (default-deny). Nothing is shared unless opted in.
// ───────────────────────────────────────────────────────────────────────────

enum ConnectionStatus {
  pending
  accepted
  declined
  revoked
}

/// A data type a property can choose to share with a specific peer.
enum ShareType {
  availability
  referrals
  scam
  bad_guest
  vendors
  transport
}

/// A trust edge between two properties. Symmetric once accepted; either side may
/// revoke. The (requester, addressee) pair is unique.
model NetworkConnection {
  id                  String           @id @default(cuid())
  requesterPropertyId String           @map("requester_property_id")
  addresseePropertyId String           @map("addressee_property_id")
  status              ConnectionStatus @default(pending)
  createdAt           DateTime         @default(now()) @map("created_at")
  respondedAt         DateTime?        @map("responded_at")

  @@unique([requesterPropertyId, addresseePropertyId])
  @@index([addresseePropertyId])
  @@map("network_connections")
}

/// What `grantor` shares with `grantee`, per data type. Directional: a grant is
/// one-way. Absence of an enabled row = not shared.
model SharingGrant {
  id                String    @id @default(cuid())
  grantorPropertyId String    @map("grantor_property_id")
  granteePropertyId String    @map("grantee_property_id")
  dataType          ShareType @map("data_type")
  enabled           Boolean   @default(true)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([grantorPropertyId, granteePropertyId, dataType])
  @@index([granteePropertyId])
  @@map("sharing_grants")
}

enum ReferralStatus {
  proposed
  accepted
  declined
  expired
  converted
}

/// An overflow referral: `from` (full) sends a guest to `to` (a peer). Cross-tenant.
/// The guest phone is withheld from the recipient until they accept (data
/// minimisation). A resulting booking is made the NORMAL guarded way in the
/// recipient's property and only LINKED here (resultingReservationId) — this
/// table never creates a reservation, so the GiST 409 guarantee is untouched.
model Referral {
  id                    String         @id @default(cuid())
  fromPropertyId        String         @map("from_property_id")
  toPropertyId          String         @map("to_property_id")
  guestName             String         @map("guest_name")
  guestPhone            String?        @map("guest_phone")
  checkIn               DateTime       @map("check_in") @db.Date
  checkOut              DateTime       @map("check_out") @db.Date
  roomTypeNeed          String?        @map("room_type_need")
  note                  String?
  status                ReferralStatus @default(proposed)
  resultingReservationId String?       @map("resulting_reservation_id")
  attributedRevenue     Decimal?       @map("attributed_revenue") @db.Decimal(10, 2)
  createdAt             DateTime       @default(now()) @map("created_at")
  respondedAt           DateTime?      @map("responded_at")

  @@index([toPropertyId])
  @@index([fromPropertyId])
  @@map("referrals")
}

/// A reciprocal-credit ledger entry: `from` earned credit from `to` for sending
/// a booking that converted. The BALANCE between two properties is DERIVED by
/// summing these — never stored as a mutable counter.
model ReferralCreditEntry {
  id             String   @id @default(cuid())
  fromPropertyId String   @map("from_property_id")
  toPropertyId   String   @map("to_property_id")
  referralId     String   @map("referral_id")
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([fromPropertyId])
  @@index([toPropertyId])
  @@map("referral_credit_entries")
}

enum ScamReportStatus {
  submitted
  verified
  disputed
  rejected
}

/// A moderated, opt-in shared scam-number report. Cross-tenant. Data minimisation:
/// the phone is stored HASHED (matched by hash), never raw — only the last 4
/// digits are kept for human recognition. Sharing is gated by the SCAM grant;
/// only `verified`, unexpired reports are shown to peers. `expiresAt` enforces a
/// retention limit. The private per-property FlaggedNumber list is unchanged.
model SharedScamReport {
  id                 String           @id @default(cuid())
  reporterPropertyId String           @map("reporter_property_id")
  phoneHash          String           @map("phone_hash")
  phoneLast4         String?          @map("phone_last4")
  reason             String
  evidenceNote       String?          @map("evidence_note")
  status             ScamReportStatus @default(submitted)
  createdByUserId    String?          @map("created_by_user_id")
  verifiedAt         DateTime?        @map("verified_at")
  expiresAt          DateTime?        @map("expires_at")
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([phoneHash])
  @@index([reporterPropertyId])
  @@map("shared_scam_reports")
}

enum GuestAlertStatus {
  submitted
  verified
  disputed
  rejected
}

enum GuestAlertCategory {
  damage
  disturbance
  rule_breach
  threat
  other
}

/// An evidence-backed, opt-in shared bad-guest alert. Cross-tenant. Built on the
/// per-property Guest blacklist (which is unchanged). Same safeguards as the scam
/// network: phone stored HASHED (last 4 + first name kept for recognition),
/// evidence required to verify, only verified+unexpired reach peers (BAD_GUEST
/// grant), retention via expiresAt, a dispute/appeal path, and audit.
model SharedGuestAlert {
  id                 String             @id @default(cuid())
  reporterPropertyId String             @map("reporter_property_id")
  guestPhoneHash     String             @map("guest_phone_hash")
  guestPhoneLast4    String?            @map("guest_phone_last4")
  guestNameMasked    String?            @map("guest_name_masked")
  category           GuestAlertCategory @default(other)
  reason             String
  evidenceNote       String?            @map("evidence_note")
  evidencePaths      String[]           @map("evidence_paths")
  status             GuestAlertStatus   @default(submitted)
  createdByUserId    String?            @map("created_by_user_id")
  verifiedAt         DateTime?          @map("verified_at")
  expiresAt          DateTime?          @map("expires_at")
  createdAt          DateTime           @default(now()) @map("created_at")

  @@index([guestPhoneHash])
  @@index([reporterPropertyId])
  @@map("shared_guest_alerts")
}

// An external iCal URL the owner pastes in (one per room per OTA). The sync
// fetches each active feed and turns its busy events into `ical` blocks.
model IcalFeed {
  id           String    @id @default(cuid())
  roomId       String    @map("room_id")
  label        String
  url          String
  active       Boolean   @default(true)
  lastSyncedAt DateTime? @map("last_synced_at")
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at")
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  blocks       Block[]
  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId   String?   @map("property_id")

  @@index([roomId])
  @@map("ical_feeds")
}

// ───────────────────────────────────────────────────────────────────────────
// ESCALATION MODULE — appended from _dropbox/prisma-escalation.prisma
// Run: npm run db:migrate:new add_escalations [--apply]
// Purely additive: new enums + one table. Does NOT touch reservations/blocks
// generated columns or the no_overlapping_confirmed_stays GiST constraint.
// ───────────────────────────────────────────────────────────────────────────

/// Which ROOT surface raised the escalation.
/// `manual` = an owner/staff member created it by hand in the queue.
enum EscalationSource {
  assistant // AI Tourism & Guesthouse Assistant (Module 4.1)
  cab // Multi-Agent Cab Coordination (Module 4.2)
  console // AI Workplace Console (Module 4.3)
  manual // raised by hand in the Escalations queue
}

/// Coarse routing bucket. Drives the Customer / Driver tabs in the queue UI.
enum EscalationCategory {
  customer // a guest-facing issue (allergy, complaint, special request)
  driver // a transport/driver issue (cancellation, no-show driver)
  booking // booking changes the agent could not complete confidently
  payment // payment / refund / suspected-scam needing a human
  maintenance // a property/maintenance issue surfaced via chat
  other
}

enum EscalationSeverity {
  low
  medium
  high
  critical
}

enum EscalationStatus {
  open
  in_progress
  resolved
  dismissed
}

/// The kind of record an escalation is attached to. Kept as a lightweight
/// (type + id) reference rather than hard FKs so an escalation can point at a
/// reservation, a guest, or a (future) trip without widening the schema now.
enum EscalationRelatedType {
  reservation
  guest
  trip
  none
}

/// Human-in-the-loop inbox shared by every ROOT agent.
///
/// An agent (or a human) files an escalation; the owner/staff triages it from
/// the Escalations queue. This is the deterministic core's side of the HITL
/// contract described in the DPR (Figures 4 & 8): the agent never takes a
/// sensitive action itself — it hands a summarised, optionally-translated
/// request to a human and waits.
model Escalation {
  id String @id @default(cuid())

  source   EscalationSource
  category EscalationCategory @default(other)
  severity EscalationSeverity @default(medium)
  status   EscalationStatus   @default(open)

  title   String // short one-line summary shown in the queue
  summary String // the agent's plain-language summary of the request/issue
  reason  String? // why the agent escalated (low confidence, sensitive action, …)

  // Who the escalation is about (the guest / driver), as the agent saw them.
  raisedByName    String? @map("raised_by_name")
  raisedByContact String? @map("raised_by_contact") // phone / email / handle
  raisedByLang    String? @map("raised_by_lang") // BCP-47-ish: "kha", "hi", "en"

  // Preserve the original message (often Khasi/Hindi) AND the translation, so a
  // human can verify the agent's understanding — central to the local-language moat.
  originalText   String? @map("original_text")
  translatedText String? @map("translated_text")

  // Lightweight link to the record this concerns (no hard FK — see enum note).
  relatedType EscalationRelatedType @default(none) @map("related_type")
  relatedId   String?               @map("related_id")

  // Correlation back to the agent's conversation, and an optional idempotency
  // key so a retrying agent doesn't create duplicate tickets (deduped in lib).
  threadRef  String? @map("thread_ref")
  externalId String? @unique @map("external_id")

  // Triage / SLA timestamps. firstResponseAt is stamped the first time status
  // leaves `open` — it drives the "Avg response time" KPI.
  assignedTo      String?   @map("assigned_to") // free-text until roles land (Phase 2); then a userId
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNote  String?   @map("resolution_note")

  // FORWARD-COMPATIBLE TENANCY. Single-property today, so this is nullable and
  // unused. When the multi-tenancy gate lands, backfill it and add
  // `propertyId String` + an index, and scope every query by it (one line in
  // src/lib/escalations.ts). The agent contract already accepts `propertyRef`.
  propertyId String? @map("property_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, severity, createdAt])
  @@index([category, status])
  @@map("escalations")
}

// Outbound message log — the LogAdapter seam for ROOT agent messaging.
// Today every message lands here with status=logged (no actual sending).
// When a real provider (WhatsApp Business, SMS, email) is configured, the
// logMessage() function in src/lib/messaging.ts routes to it and updates
// the status. Agents call POST /api/agent/messages; the owner views the log
// at /messages. Schema is forward-compatible: propertyId is nullable today.

enum MessageChannel {
  whatsapp
  sms
  email
  manual
}

enum MessageStatus {
  queued
  sent
  failed
  logged
}

enum MessageSource {
  assistant
  cab
  console
  system
}

model OutboundMessage {
  id            String         @id @default(cuid())
  source        MessageSource
  channel       MessageChannel
  to            String
  body          String
  status        MessageStatus  @default(logged)
  sentAt        DateTime?      @map("sent_at")
  error         String?
  guestId       String?        @map("guest_id")
  reservationId String?        @map("reservation_id")
  propertyId    String?        @map("property_id")
  createdAt     DateTime       @default(now()) @map("created_at")

  guest       Guest?       @relation(fields: [guestId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([guestId, createdAt])
  @@index([reservationId])
  @@index([status, createdAt])
  @@map("outbound_messages")
}

// Phone numbers flagged as potential scammers. Checked at booking time so the
// owner sees a warning before accepting a reservation from a known bad number.
model FlaggedNumber {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  // Tenant (multi-property). Single-property today; backfilled + scoped by the
  // Prisma tenant extension. See src/lib/tenant.ts.
  propertyId String? @map("property_id")

  @@map("flagged_numbers")
}

enum RefundStatus {
  requested
  approved
  partial
  rejected
}

// Owner-editable cancellation policy (single row, like PricingPolicy). Free-
// cancellation windows are in days before check-in; a shorter window applies on
// peak dates — a check-in that falls inside a Season with a positive adjustment.
model CancellationPolicy {
  id                    String   @id @default(cuid())
  enabled               Boolean  @default(true)
  freeCancelDaysDefault Int      @default(4) @map("free_cancel_days_default")
  freeCancelDaysPeak    Int      @default(2) @map("free_cancel_days_peak")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")
  // Forward-compatible tenancy (single-property today; unused).
  propertyId            String?  @map("property_id")

  @@map("cancellation_policy")
}

// A refund against a cancelled booking. Owner-committed — agents never refund;
// the policy suggests an amount, but the owner may approve a partial. Cancelling
// stays a human (HITL) action; this records the money side of it.
model Refund {
  id            String       @id @default(cuid())
  reservationId String       @map("reservation_id")
  amount        Decimal      @db.Decimal(10, 2)
  status        RefundStatus @default(requested)
  reason        String?
  approvedAt    DateTime?    @map("approved_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  // Forward-compatible tenancy (single-property today; unused).
  propertyId    String?      @map("property_id")
  reservation   Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@map("refunds")
}

enum ComplaintCategory {
  maintenance
  cleanliness
  food
  noise
  staff
  billing
  other
}

enum ComplaintPriority {
  low
  medium
  high
}

enum ComplaintStatus {
  open
  in_progress
  resolved
}

// A logged guest complaint/issue the owner tracks to resolution. Urgent (high)
// complaints also file an Escalation into the shared HITL queue so they surface
// on /needs-you. Optional links to the guest/reservation they concern.
model Complaint {
  id             String            @id @default(cuid())
  guestId        String?           @map("guest_id")
  reservationId  String?           @map("reservation_id")
  category       ComplaintCategory @default(other)
  priority       ComplaintPriority @default(medium)
  status         ComplaintStatus   @default(open)
  assignee       String? // free-text until roles land (Phase 2)
  description    String
  resolutionNote String?           @map("resolution_note")
  satisfaction   Int? // 1–5 guest satisfaction, captured on resolution
  escalationId   String?           @map("escalation_id") // set when an urgent one is escalated
  resolvedAt     DateTime?         @map("resolved_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at")
  // Forward-compatible tenancy (single-property today; unused).
  propertyId     String?           @map("property_id")

  guest       Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([status, priority, createdAt])
  @@map("complaints")
}
