# OTA guest assistant (ADK sidecar) — copy to .env and fill in.

# Gemini (the brain). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash-lite"   # optional override (flash-lite = lighter + higher free-tier quota)
GEMINI_FALLBACK_MODEL="gemini-2.5-flash"  # optional; used on a turn's last attempt if the primary keeps returning empty

# The PMS seam the tools call. OTA_AGENT_TOKEN must equal the OTA app's AGENT_TOKEN.
OTA_BASE_URL="https://guest-house-ops-hub.vercel.app"
OTA_AGENT_TOKEN=""

# The channel a booking is attributed to (the seeded "Assistant (ROOT)" channel).
OTA_CHANNEL_ID="cmr6b9eio0000y0ko8f8y5r1x"

# Optional shared secret between the OTA /assistant proxy and this server.
# If set here, it must equal ASSISTANT_AGENT_TOKEN in the OTA app's env.
ASSISTANT_AGENT_TOKEN=""
