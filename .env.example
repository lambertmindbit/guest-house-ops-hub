# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Supabase Postgres connection (Project Settings → Database → Connection string).
#
# DATABASE_URL = the app's RUNTIME connection. On Vercel this MUST be the
# Transaction pooler (port 6543) with pgbouncer=true, so serverless functions
# reuse warm connections instead of opening a new one (TLS handshake) per request
# — this is the single biggest speed fix for the deployed app.
#   postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = the DIRECT connection (port 5432). Used ONLY by Prisma migrations,
# which can't run through the transaction pooler. Locally you can point this at
# the same value as DATABASE_URL if you use the direct connection in dev.
#   postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# The integration test suite (Vitest) creates/deletes real rows. Point this at a
# SEPARATE disposable database so tests never touch production data. If unset,
# `npm test` refuses to run unless you also set ALLOW_PROD_DB_TESTS=1.
TEST_DATABASE_URL=""

# Single-owner login (Slice 9). Set these to your own values.
OWNER_EMAIL="owner@example.com"
OWNER_PASSWORD="change-me"
# Secret used to sign the session cookie (any long random string).
AUTH_SECRET="generate-a-long-random-string"

# The property's IANA timezone. "Today" (dashboard, calendar, housekeeping,
# messaging triggers) is computed in this zone — NOT the server's, which is UTC
# on Vercel. Defaults to Asia/Kolkata if unset.
APP_TIMEZONE="Asia/Kolkata"

# iCal export feed token (Phase 2). Included in public .ics feed URLs so OTAs
# can read a room's busy dates without logging in. Use a long random string.
ICAL_FEED_TOKEN="generate-a-long-random-string"

# Secret the daily Vercel Cron uses to authorize /api/cron/sync. Set the same
# value in the Vercel project's environment variables.
CRON_SECRET="generate-a-long-random-string"

# Shared secret for the ROOT agent API seam (POST /api/agent/*).
# OPTIONAL: leave unset and all /api/agent/* routes return 401 (fail closed),
# so the seam stays dark until a real agent is pointed at it. When ready, set
# a long random string here, in Vercel, and in the agent service configuration.
#   openssl rand -hex 32
AGENT_TOKEN=""

# Assistant runtime (docs/AGENT-GENUI-PLAN.md, Phase 2). The /assistant chat
# proxies to the ADK Python sidecar when these are set; UNSET → the built-in
# Phase-1 stub answers instead (production stays working before the agent is
# deployed). ASSISTANT_AGENT_URL is the agent's NDJSON endpoint; the optional
# token is sent as a Bearer to it.
ASSISTANT_AGENT_URL=""     # e.g. https://<your-agent-host>/chat
ASSISTANT_AGENT_TOKEN=""

# Public guest chat widget (no login) at /chat + /api/public/assistant. OFF by
# default — set to "true" only once the agent is deployed with public mode. In
# public mode the assistant answers availability/prices and files a booking
# REQUEST for the owner to confirm; it can never create a reservation.
PUBLIC_CHAT_ENABLED=""     # "true" to turn the public widget on

# Token for the automated email-ingestion webhook (POST /api/ingest/email).
# OPTIONAL: leave unset until you wire up an inbox/forwarding rule — until then
# the owner pastes confirmation emails into the Inbox screen, which doesn't use
# this. When you do automate it, set a long random string here and on whatever
# forwards the emails (e.g. a Cloudflare Email Worker).
INGEST_TOKEN=""

# Guest ID document upload (DigitalOcean Spaces). OPTIONAL: leave unset and the
# upload UI shows a "not configured" hint; everything else works. To enable,
# create a PRIVATE Spaces bucket, generate a key under API → Spaces Keys, and set:
SPACES_KEY=""                   # Spaces access key ID
SPACES_SECRET=""                # server-only secret — never expose to the client
SPACES_REGION="blr1"            # optional; defaults to "blr1" (Bangalore)
SPACES_BUCKET="guest-ids"       # optional; defaults to "guest-ids"
SPACES_ENDPOINT=""              # optional; defaults to <region>.digitaloceanspaces.com
                                # (set it to use any other S3-compatible storage)

# Web Push (owner notifications). Generate with: npx web-push generate-vapid-keys
# The public key is exposed to the browser (NEXT_PUBLIC_*); keep the private key secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
