// Prisma schema for the Guest House Ops Hub (Phase 1).
//
// IMPORTANT — the correctness core lives partly in raw SQL (see the init
// migration), because Prisma cannot express it:
//   * `stay` / `period` are real Postgres DATERANGE columns, GENERATED from
//     check_in/check_out (resp. start/end) as half-open `[)` ranges. They are
//     declared here as `Unsupported("daterange")?` so Prisma tracks the column
//     but never tries to write it — Postgres always derives it.
//   * The no-double-booking guarantee is a GiST EXCLUDE constraint on
//     reservations.stay, added by hand in the init migration.
// Do not try to "fix" these into normal Prisma fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through the Supabase pooler (port 6543, pgbouncer=true) so
  // serverless functions reuse warm connections instead of doing a TLS handshake
  // per request. Migrations need a DIRECT connection (port 5432) — pgbouncer's
  // transaction pooling can't run them. DIRECT_URL falls back to DATABASE_URL
  // locally if you keep using the direct connection in dev.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReservationStatus {
  confirmed
  cancelled
  no_show
}

// How a block came to exist: created by the owner, or imported from an OTA's
// iCal feed. Imported blocks are owned by the sync and replaced on each run.
enum BlockSource {
  manual
  ical
}

enum PaymentMode {
  cash
  upi
  card
  bank
  ota_collect
}

// Lifecycle of a parsed inbound (OTA email) booking awaiting the owner's review.
enum InboundStatus {
  pending
  imported
  dismissed
}

model RoomType {
  id           String  @id @default(cuid())
  name         String
  baseRate     Decimal @map("base_rate") @db.Decimal(10, 2)
  maxOccupancy Int     @map("max_occupancy")
  rateFloor    Decimal @map("rate_floor") @db.Decimal(10, 2)
  rateCeiling  Decimal @map("rate_ceiling") @db.Decimal(10, 2)
  rooms        Room[]

  @@map("room_types")
}

model Room {
  id           String        @id @default(cuid())
  roomTypeId   String        @map("room_type_id")
  label        String
  // Housekeeping: a room "needs cleaning" when a guest has checked out since
  // this timestamp. Marking a room clean sets it to now.
  lastCleanedAt DateTime?    @map("last_cleaned_at")
  // Manual override: lets the owner flag a room dirty when there's no checkout
  // to derive from (dust, maintenance, own use). Cleared on "mark clean".
  needsCleaningFlag Boolean  @default(false) @map("needs_cleaning_flag")
  // Retiring a room: archived rooms drop off the calendar, availability,
  // housekeeping, and the new-booking picker, but their history is preserved
  // (FKs are RESTRICT — a used room can never be hard-deleted, only archived).
  archivedAt   DateTime?     @map("archived_at")
  roomType     RoomType      @relation(fields: [roomTypeId], references: [id])
  reservations Reservation[]
  blocks       Block[]
  icalFeeds    IcalFeed[]

  @@map("rooms")
}

model Channel {
  id             String        @id @default(cuid())
  name           String
  commissionPct  Decimal       @map("commission_pct") @db.Decimal(5, 2)
  collectsPayment Boolean      @map("collects_payment")
  reservations   Reservation[]

  @@map("channels")
}

model Guest {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique
  email        String?
  notes        String?
  // Government ID reference (text only — no document/photo upload, which would
  // need object storage). Blacklist flag warns the owner at booking time.
  idNumber     String?       @map("id_number")
  // Path to a scanned ID document in object storage (Supabase Storage). Null
  // until uploaded; storage is optional and configured via env (see docs).
  idDocumentPath String?     @map("id_document_path")
  blocked      Boolean       @default(false)
  blockReason  String?       @map("block_reason")
  // C-Form (Form C under Registration of Foreigners Rules, 1992).
  // All nullable — only populated for foreign national guests.
  nationality       String?   @map("nationality")
  passportNumber    String?   @map("passport_number")
  passportIssueDate DateTime? @map("passport_issue_date") @db.Date
  passportIssuePlace String?  @map("passport_issue_place")
  passportExpiry    DateTime? @map("passport_expiry") @db.Date
  visaNumber        String?   @map("visa_number")
  visaType          String?   @map("visa_type")
  visaIssueDate     DateTime? @map("visa_issue_date") @db.Date
  visaIssuePlace    String?   @map("visa_issue_place")
  visaExpiry        DateTime? @map("visa_expiry") @db.Date
  portOfEntry       String?   @map("port_of_entry")
  arrivalInIndia    DateTime? @map("arrival_in_india") @db.Date
  purposeOfVisit    String?   @map("purpose_of_visit")
  reservations Reservation[]

  @@map("guests")
}

model Reservation {
  id              String                   @id @default(cuid())
  roomId          String                   @map("room_id")
  guestId         String                   @map("guest_id")
  channelId       String                   @map("channel_id")
  otaRef          String?                  @map("ota_ref")
  checkIn         DateTime                 @map("check_in") @db.Date
  checkOut        DateTime                 @map("check_out") @db.Date
  // Generated in the DB from check_in/check_out as a half-open [) daterange.
  stay            Unsupported("daterange")? @map("stay")
  status          ReservationStatus        @default(confirmed)
  // Live arrival/departure stamps. Orthogonal to `status` (a confirmed booking
  // may or may not be in-house yet) and to `stay`, so the exclusion constraint
  // is untouched. Drive the Today board's in-house view + housekeeping handoff.
  checkedInAt     DateTime?                @map("checked_in_at")
  checkedOutAt    DateTime?                @map("checked_out_at")
  arrivalTime     String?                  @map("arrival_time")
  specialRequests String?                  @map("special_requests")
  grossAmount     Decimal?                 @map("gross_amount") @db.Decimal(10, 2)
  // Amount expected upfront to hold the room. Separate from grossAmount so the
  // owner can track whether the deposit has arrived before check-in.
  advanceRequired Decimal?                 @map("advance_required") @db.Decimal(10, 2)
  createdAt       DateTime                 @default(now()) @map("created_at")

  room     Room      @relation(fields: [roomId], references: [id])
  guest    Guest     @relation(fields: [guestId], references: [id])
  channel  Channel   @relation(fields: [channelId], references: [id])
  payments Payment[]

  @@index([roomId])
  @@index([guestId])
  @@map("reservations")
}

// Money received against a reservation. A booking can have several (e.g. a
// deposit then the balance). Sum of payments vs gross_amount gives the balance.
model Payment {
  id            String      @id @default(cuid())
  reservationId String      @map("reservation_id")
  amount        Decimal     @db.Decimal(10, 2)
  mode          PaymentMode
  // True when this payment is the advance/deposit (not the final balance).
  isAdvance     Boolean     @default(false) @map("is_advance")
  paidAt        DateTime    @default(now()) @map("paid_at")
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@map("payments")
}

model Block {
  id        String                   @id @default(cuid())
  roomId    String                   @map("room_id")
  startDate DateTime                 @map("start_date") @db.Date
  endDate   DateTime                 @map("end_date") @db.Date
  // Generated in the DB from start_date/end_date as a half-open [) daterange.
  period    Unsupported("daterange")? @map("period")
  reason    String?
  source    BlockSource              @default(manual)
  // Set for imported blocks: which feed they came from and the source event UID.
  feedId      String?                @map("feed_id")
  externalUid String?                @map("external_uid")
  room      Room                     @relation(fields: [roomId], references: [id])
  feed      IcalFeed?                @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([feedId])
  @@map("blocks")
}

// A booking parsed out of an OTA confirmation email, staged for the owner to
// review and confirm before it becomes a real Reservation. Decouples "how the
// email arrives" (paste now; inbox webhook later) from "what we do with it".
// Parsed fields are best-effort and nullable — the owner corrects on review.
model InboundBooking {
  id            String        @id @default(cuid())
  source        String        // detected channel, e.g. "Booking.com" / "Agoda" / "Unknown"
  otaRef        String?       @map("ota_ref") // used to dedupe re-sent emails
  rawText       String        @map("raw_text")
  guestName     String?       @map("guest_name")
  guestPhone    String?       @map("guest_phone")
  checkIn       DateTime?     @map("check_in") @db.Date
  checkOut      DateTime?     @map("check_out") @db.Date
  roomTypeHint  String?       @map("room_type_hint")
  amount        Decimal?      @db.Decimal(10, 2)
  status        InboundStatus @default(pending)
  reservationId String?       @map("reservation_id") // set once imported
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@map("inbound_bookings")
}

// A cost the property incurred. Attributed to Finance by `date`. Turns the
// revenue-only view into true net profit (revenue − commission − expenses).
model Expense {
  id          String       @id @default(cuid())
  date        DateTime     @db.Date
  category    String
  amount      Decimal      @db.Decimal(10, 2)
  note        String?
  paymentMode PaymentMode? @map("payment_mode")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([date])
  @@map("expenses")
}

// Single configurable pricing policy (one row). The pricing engine starts from a
// room type's base_rate and compounds the applicable adjustments below, then
// clamps to [rate_floor, rate_ceiling]. All adjustments are advisory — they only
// suggest a nightly rate and pre-fill the booking amount; nothing is pushed to OTAs.
// Percentages may be negative (a discount). Zero / null = that rule is off.
model PricingPolicy {
  id                    String   @id @default(cuid())
  enabled               Boolean  @default(true)
  // Weekday numbers (0=Sun … 6=Sat) that count as "weekend", + their uplift.
  weekendDays           Int[]    @default([5, 6]) @map("weekend_days")
  weekendAdjustPct      Decimal  @default(0) @map("weekend_adjust_pct") @db.Decimal(6, 2)
  // Early-bird discount when the booking is at least N days out.
  leadEarlyDays         Int?     @map("lead_early_days")
  leadEarlyAdjustPct    Decimal? @map("lead_early_adjust_pct") @db.Decimal(6, 2)
  // Last-minute uplift when the booking is within M days of check-in.
  leadLateDays          Int?     @map("lead_late_days")
  leadLateAdjustPct     Decimal? @map("lead_late_adjust_pct") @db.Decimal(6, 2)
  // Occupancy uplift when that night's derived occupancy ≥ threshold %.
  occupancyThresholdPct Int?     @map("occupancy_threshold_pct")
  occupancyAdjustPct    Decimal? @map("occupancy_adjust_pct") @db.Decimal(6, 2)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("pricing_policy")
}

// A named date range (festival / peak season) with a rate adjustment. Inclusive
// of both endpoints. Owner-managed in Settings.
model Season {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  adjustPct Decimal  @map("adjust_pct") @db.Decimal(6, 2)

  @@map("seasons")
}

// An explicit nightly rate the owner pins for a room type on a specific date.
// Overrides win over every rule (and over the floor/ceiling clamp).
model RateOverride {
  id         String   @id @default(cuid())
  roomTypeId String   @map("room_type_id")
  date       DateTime @db.Date
  rate       Decimal  @db.Decimal(10, 2)

  @@unique([roomTypeId, date])
  @@map("rate_overrides")
}

// Single-row table holding the owner's property profile. Read with findFirst;
// the first save creates the row. Used by invoices/receipts and as defaults
// (check-in/out times) elsewhere.
model PropertySettings {
  id           String   @id @default(cuid())
  name         String   @default("My Guest House")
  checkInTime  String   @default("14:00") @map("check_in_time")
  checkOutTime String   @default("11:00") @map("check_out_time")
  currency     String   @default("INR")
  timezone     String   @default("Asia/Kolkata")
  address      String?
  gstNumber    String?  @map("gst_number")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("property_settings")
}

// An external iCal URL the owner pastes in (one per room per OTA). The sync
// fetches each active feed and turns its busy events into `ical` blocks.
model IcalFeed {
  id           String    @id @default(cuid())
  roomId       String    @map("room_id")
  label        String
  url          String
  active       Boolean   @default(true)
  lastSyncedAt DateTime? @map("last_synced_at")
  lastError    String?   @map("last_error")
  createdAt    DateTime  @default(now()) @map("created_at")
  room         Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  blocks       Block[]

  @@index([roomId])
  @@map("ical_feeds")
}

// ───────────────────────────────────────────────────────────────────────────
// ESCALATION MODULE — appended from _dropbox/prisma-escalation.prisma
// Run: npm run db:migrate:new add_escalations [--apply]
// Purely additive: new enums + one table. Does NOT touch reservations/blocks
// generated columns or the no_overlapping_confirmed_stays GiST constraint.
// ───────────────────────────────────────────────────────────────────────────

/// Which ROOT surface raised the escalation.
/// `manual` = an owner/staff member created it by hand in the queue.
enum EscalationSource {
  assistant // AI Tourism & Guesthouse Assistant (Module 4.1)
  cab       // Multi-Agent Cab Coordination (Module 4.2)
  console   // AI Workplace Console (Module 4.3)
  manual    // raised by hand in the Escalations queue
}

/// Coarse routing bucket. Drives the Customer / Driver tabs in the queue UI.
enum EscalationCategory {
  customer    // a guest-facing issue (allergy, complaint, special request)
  driver      // a transport/driver issue (cancellation, no-show driver)
  booking     // booking changes the agent could not complete confidently
  payment     // payment / refund / suspected-scam needing a human
  maintenance // a property/maintenance issue surfaced via chat
  other
}

enum EscalationSeverity {
  low
  medium
  high
  critical
}

enum EscalationStatus {
  open
  in_progress
  resolved
  dismissed
}

/// The kind of record an escalation is attached to. Kept as a lightweight
/// (type + id) reference rather than hard FKs so an escalation can point at a
/// reservation, a guest, or a (future) trip without widening the schema now.
enum EscalationRelatedType {
  reservation
  guest
  trip
  none
}

/// Human-in-the-loop inbox shared by every ROOT agent.
///
/// An agent (or a human) files an escalation; the owner/staff triages it from
/// the Escalations queue. This is the deterministic core's side of the HITL
/// contract described in the DPR (Figures 4 & 8): the agent never takes a
/// sensitive action itself — it hands a summarised, optionally-translated
/// request to a human and waits.
model Escalation {
  id String @id @default(cuid())

  source   EscalationSource
  category EscalationCategory  @default(other)
  severity EscalationSeverity  @default(medium)
  status   EscalationStatus    @default(open)

  title   String  // short one-line summary shown in the queue
  summary String  // the agent's plain-language summary of the request/issue
  reason  String? // why the agent escalated (low confidence, sensitive action, …)

  // Who the escalation is about (the guest / driver), as the agent saw them.
  raisedByName    String? @map("raised_by_name")
  raisedByContact String? @map("raised_by_contact") // phone / email / handle
  raisedByLang    String? @map("raised_by_lang")    // BCP-47-ish: "kha", "hi", "en"

  // Preserve the original message (often Khasi/Hindi) AND the translation, so a
  // human can verify the agent's understanding — central to the local-language moat.
  originalText   String? @map("original_text")
  translatedText String? @map("translated_text")

  // Lightweight link to the record this concerns (no hard FK — see enum note).
  relatedType EscalationRelatedType @default(none) @map("related_type")
  relatedId   String?               @map("related_id")

  // Correlation back to the agent's conversation, and an optional idempotency
  // key so a retrying agent doesn't create duplicate tickets (deduped in lib).
  threadRef  String? @map("thread_ref")
  externalId String? @unique @map("external_id")

  // Triage / SLA timestamps. firstResponseAt is stamped the first time status
  // leaves `open` — it drives the "Avg response time" KPI.
  assignedTo      String?   @map("assigned_to") // free-text until roles land (Phase 2); then a userId
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNote  String?   @map("resolution_note")

  // FORWARD-COMPATIBLE TENANCY. Single-property today, so this is nullable and
  // unused. When the multi-tenancy gate lands, backfill it and add
  // `propertyId String` + an index, and scope every query by it (one line in
  // src/lib/escalations.ts). The agent contract already accepts `propertyRef`.
  propertyId String? @map("property_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, severity, createdAt])
  @@index([category, status])
  @@map("escalations")
}

// Phone numbers flagged as potential scammers. Checked at booking time so the
// owner sees a warning before accepting a reservation from a known bad number.
model FlaggedNumber {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("flagged_numbers")
}
