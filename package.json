{
  "name": "guest-house-ops-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3100",
    "build": "prisma generate && next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:new": "node scripts/migrate.mjs",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "shots": "node scripts/screenshots.mjs",
    "docs:html": "node scripts/md-to-html.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "date-fns": "^4.1.0",
    "next": "^15.2.0",
    "node-ical": "^0.26.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "dotenv": "^16.4.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.2.0",
    "marked": "^18.0.5",
    "playwright": "^1.60.0",
    "postcss": "^8.5.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
